  edge [color="#5b6b62", arrowhead=crow, arrowtail=none, fontname="Helvetica", fontsize=8];

  // ---- IdentitĂ© ----
  authusers   [label="{auth.users|id (PK)\lemail\lidentities (Google)\l}", fillcolor="#e8eef9"];
  profiles    [label="{profiles|id (PKâ†’auth.users)\ldisplay_name\lavatar_url\laccount_type\ltrust_score\l}", fillcolor="#e8f9ef"];
  priv        [label="{user_private_profiles|user_id (PKâ†’profiles)\lphone\llegal_*, address_*\l}"];
  vehicles    [label="{user_vehicles|id (PK)\luser_id â†’profiles\lseats, energy\l}"];

  // ---- Pivot ressources ----
  resources   [label="{mobility_resources  (PIVOT)|id (PK)\lowner_user_id â†’profiles\lorganization_id â†’orgs\lresource_type (enum)\lvisibility, location(geo)\lsuggested_price_cents\l}", fillcolor="#00b868", fontcolor="white"];

  // ---- Covoiturage (multi-passagers) ----
  rides       [label="{rides|id (PK)\lresource_id â†’resources (1:1)\ldriver_id â†’profiles\lorigin/destination_label (+geo)\lseats_total, seats_available â—€ restantes\lstatus (publishedâ€¦)\l}", fillcolor="#e8f9ef"];
  ridebk      [label="{ride_bookings  (MULTI-PASSAGERS)|id (PK)\lride_id â†’rides\lpassenger_id â†’profiles\lseats (1..8) â—€ places/rĂ©sa\lstatus: pendingâ†’acceptedâ†’completed\lUNIQUE(ride_id,passenger_id)\l}", fillcolor="#fff3d6"];

  // ---- Bornes ----
  charge      [label="{charging_stations|id (PK)\lresource_id â†’resources (1:1)\lconnector_type, power_kw\l}"];
  chargebk    [label="{charging_bookings|id (PK)\lstation_id â†’charging_stations\luser_id â†’profiles\lstarts_at/ends_at (anti-chevauchement)\l}", fillcolor="#fff3d6"];

  // ---- Parking (brique cĹ“ur) ----
  parking     [label="{parking_spots|id (PK)\lresource_id â†’resources (1:1)\lspot_type, max_height_cm\l}"];
  parkingbk   [label="{parking_bookings|id (PK)\lparking_spot_id â†’parking_spots\luser_id â†’profiles\lstarts_at/ends_at (anti-chevauchement)\l}", fillcolor="#fff3d6"];

  // ---- Organisations ----
