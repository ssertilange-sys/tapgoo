digraph TAPGOO_OS {
  graph [rankdir=LR, splines=spline, nodesep=0.5, ranksep=1.0, bgcolor="white", fontname="Helvetica", label="TAPGOO OS â€” SchĂ©ma cible MVP (cĹ“ur : covoiturage Â· bornes Â· parking)\nmobility_resources = pivot des 3 briques Â· rĂ©servations multi-passagers natives", labelloc="t", fontsize=18];
