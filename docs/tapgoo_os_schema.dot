  orgmem      [label="{organization_members|id (PK)\lorganization_id â†’orgs\luser_id â†’profiles\lrole (RBAC)\l}", fillcolor="#e8eef9"];

  // ---- Messagerie (reprise 1:1) ----
  conv        [label="{conversations|id (PK)\lride_id â†’rides (contexte)\l}"];
